{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID from Firebase Auth" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "tier": { "type": "string", "enum": ["free", "pro"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "tier", "createdAt"]
    },
    "Case": {
      "title": "Case",
      "description": "A medical case containing reports and analyses",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Owner of the case" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "analyzed"] },
        "reviewCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/cases/{caseId}": {
      "schema": { "$ref": "#/entities/Case" },
      "description": "Medical cases belonging to users"
    }
  }
}
